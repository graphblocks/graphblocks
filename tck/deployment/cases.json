  {
    "name": "rollout_gate_holds_advances_and_aborts_without_unsafe_rollback",
    "kind": "rollout_gate",
    "rolloutId": "rollout-1",
    "stableRevisionId": "rev-stable",
    "candidateRevisionId": "rev-canary",
    "canarySteps": [
      {
        "stepId": "canary-10",
        "trafficPercent": 10,
        "minimumSamples": 20,
        "minimumDurationSeconds": 60
      }
    ],
    "evaluations": [
      {
        "currentStepIndex": 2,
        "stepId": "canary-10",
        "passed": true,
        "sampleCount": 19,
        "durationSeconds": 120
      },
      {
        "currentStepIndex": 2,
        "stepId": "canary-10",
        "passed": true,
        "sampleCount": 20,
        "durationSeconds": 60
      },
      {
        "currentStepIndex": 2,
        "stepId": "canary-10",
        "passed": false,
        "reason": "quality_gate_failed",
        "sampleCount": 20,
        "durationSeconds": 60,
        "nonReversibleEffectObserved": true
      }
    ],
    "expected": {
      "decisions": [
        {
          "decision": "hold",
          "reason": "minimum_samples_not_met",
          "nextStepIndex": 2,
          "nextStatus": "running",
          "automaticRollbackAllowed": true
        },
        {
          "decision": "advance",
          "reason": "gate_passed",
          "nextStepIndex": 3,
          "nextStatus": "running",
          "automaticRollbackAllowed": true
        },
        {
          "decision": "abort",
          "reason": "quality_gate_failed",
          "nextStepIndex": 2,
          "nextStatus": "aborted",
          "automaticRollbackAllowed": false
        }
      ]
    }
  },
