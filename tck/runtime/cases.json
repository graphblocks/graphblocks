[
  {
    "name": "prompt_render_output",
    "document": {
      "apiVersion": "graphblocks.ai/v1alpha3",
      "kind": "Graph",
      "metadata": {
        "name": "runtime-prompt-render"
      },
      "spec": {
        "interface": {
          "inputs": {
            "message": "graphblocks.ai/Text@1"
          },
          "outputs": {
            "prompt": "graphblocks.ai/Text@1"
          }
        },
        "nodes": {
          "render": {
            "block": "prompt.render@1",
            "config": {
              "template": "Test {message.text}"
            },
            "inputs": {
              "message": "$input.message"
            },
            "outputs": {
              "prompt": "$output.prompt"
            }
          }
        }
      }
    },
    "inputs": {
      "message": {
        "text": "ok"
      }
    },
    "expected": {
      "status": "succeeded",
      "terminal_kind": "run_succeeded",
      "outputs": {
        "prompt": "Test ok"
      }
    }
  },
  {
    "name": "control_map_renders_each_item",
    "document": {
      "apiVersion": "graphblocks.ai/v1alpha3",
      "kind": "Graph",
      "metadata": {
        "name": "runtime-control-map"
      },
      "spec": {
        "interface": {
          "inputs": {
            "items": "graphblocks.ai/Items@1"
          },
          "outputs": {
            "values": "graphblocks.ai/Values@1"
          }
        },
        "nodes": {
          "map": {
            "block": "control.map@2",
            "inputs": {
              "items": "$input.items"
            },
            "outputs": {
              "values": "$output.values"
            },
            "config": {
              "block": "prompt.render@1",
              "inputName": "message",
              "outputName": "prompt",
              "config": {
                "template": "Item {message.index}: {message.text}"
              }
            }
          }
        }
      }
    },
    "inputs": {
      "items": [
        {
          "index": 1,
          "text": "alpha"
        },
        {
          "index": 2,
          "text": "beta"
        }
      ]
    },
    "expected": {
      "status": "succeeded",
      "terminal_kind": "run_succeeded",
      "outputs": {
        "values": [
          "Item 1: alpha",
          "Item 2: beta"
        ]
      }
    }
  },
  {
    "name": "control_select_treats_null_as_present",
    "document": {
      "apiVersion": "graphblocks.ai/v1alpha3",
      "kind": "Graph",
      "metadata": {
        "name": "runtime-control-select"
      },
      "spec": {
        "interface": {
          "inputs": {
            "cases": "graphblocks.ai/Cases@1"
          },
          "outputs": {
            "selected": "graphblocks.ai/SelectedKey@1",
            "value": "graphblocks.ai/SelectedValue@1"
          }
        },
        "nodes": {
          "select": {
            "block": "control.select@1",
            "inputs": {
              "cases": "$input.cases"
            },
            "outputs": {
              "selected": "$output.selected",
              "value": "$output.value"
            },
            "config": {
              "order": [
                "preferred",
                "fallback"
              ],
              "default": "unused"
            }
          }
        }
      }
    },
    "inputs": {
      "cases": {
        "preferred": null,
        "fallback": "fallback-value"
      }
    },
    "expected": {
      "status": "succeeded",
      "terminal_kind": "run_succeeded",
      "outputs": {
        "selected": "preferred",
        "value": null
      }
    }
  },
  {
    "name": "tools_resolve_feeds_scripted_agent",
    "document": {
      "apiVersion": "graphblocks.ai/v1alpha3",
      "kind": "Graph",
      "metadata": {
        "name": "runtime-tool-resolution-agent"
      },
      "spec": {
        "interface": {
          "inputs": {
            "messages": "graphblocks.ai/Messages@1"
          },
          "outputs": {
            "candidate": "graphblocks.ai/AssistantCandidate@1"
          }
        },
        "nodes": {
          "resolve": {
            "block": "tools.resolve@1",
            "config": {
              "effectivePolicySnapshotId": "policy-snapshot-1",
              "definitions": [
                {
                  "name": "knowledge.search",
                  "description": "Search support documentation.",
                  "inputSchema": "schemas/SearchRequest@1"
                }
              ],
              "bindings": [
                {
                  "bindingId": "binding-search",
                  "toolName": "knowledge.search",
                  "implementation": {
                    "kind": "block",
                    "block": "knowledge.search@1"
                  },
                  "effects": [
                    "external_read"
                  ],
                  "approval": "never",
                  "idempotency": "not_applicable"
                }
              ],
              "scope": {
                "principalTools": [
                  "knowledge.search"
                ]
              }
            }
          },
          "agent": {
            "block": "agent.run@1",
            "config": {
              "response": "Tool-aware response."
            },
            "inputs": {
              "messages": "$input.messages",
              "tools": "resolve.tools"
            },
            "outputs": {
              "candidate": "$output.candidate"
            }
          }
        }
      }
    },
    "inputs": {
      "messages": [
        {
          "role": "user",
          "content": "Search support docs"
        }
      ]
    },
    "expected": {
      "status": "succeeded",
      "terminal_kind": "run_succeeded",
      "outputs": {
        "candidate": {
          "finishReason": "scripted",
          "modelVisibleTools": [
            {
              "allowedForPrincipal": true,
              "bindingDigest": "sha256:0009e032b3ae7f7e91b189fa31c1714f0f5378f17cedc7f64c69932276e289f7",
              "definitionDigest": "sha256:de8e67b8496b952810f49560dc36761f7b5b05c0c3c11c2657f1b540b35aea23",
              "effectivePolicySnapshotId": "policy-snapshot-1",
              "resolvedToolId": "sha256:757dace543cd9b8a9fce1eb1561c4cc72efc7ad371dd7977fcaf81cbbc641bd1",
              "toolName": "knowledge.search",
              "validUntil": null
            }
          ],
          "text": "Tool-aware response.",
          "toolCount": 1
        }
      }
    }
  },
  {
    "name": "policy_stopped_turn_rejects_commit",
    "document": {
      "apiVersion": "graphblocks.ai/v1alpha3",
      "kind": "Graph",
      "metadata": {
        "name": "runtime-policy-stopped-turn"
      },
      "spec": {
        "interface": {
          "inputs": {
            "message": "graphblocks.ai/Message@1"
          },
          "outputs": {
            "answer": "graphblocks.ai/Answer@1"
          }
        },
        "nodes": {
          "begin": {
            "block": "conversation.begin_turn@1"
          },
          "render": {
            "block": "prompt.render@1",
            "config": {
              "template": "Answer: {message.text}"
            },
            "inputs": {
              "message": "$input.message"
            }
          },
          "generate": {
            "block": "model.generate@1",
            "config": {
              "script": {
                "Answer: Hello": "blocked answer"
              }
            },
            "inputs": {
              "prompt": "render.prompt"
            }
          },
          "stop": {
            "block": "conversation.policy_stop_turn@1",
            "inputs": {
              "transaction": "begin.transaction"
            }
          },
          "commit": {
            "block": "conversation.commit_turn@1",
            "inputs": {
              "transaction": "stop.transaction",
              "candidate": "generate.response"
            },
            "outputs": {
              "answer": "$output.answer"
            }
          }
        }
      }
    },
    "inputs": {
      "message": {
        "text": "Hello"
      }
    },
    "expected": {
      "status": "failed",
      "terminal_kind": "run_failed",
      "outputs": {}
    }
  },
