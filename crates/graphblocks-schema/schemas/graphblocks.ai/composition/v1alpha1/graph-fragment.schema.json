{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graphblocks.ai/composition/v1alpha1/graph-fragment.schema.json",
  "title": "GraphBlocks GraphFragment",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "graphblocks.ai/composition/v1alpha1" },
    "kind": { "const": "GraphFragment" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": { "$ref": "#/$defs/spec" }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "schemaId": {
      "type": "string",
      "pattern": "^\\S+@[1-9][0-9]*$"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "ports": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/name" },
      "additionalProperties": { "$ref": "#/$defs/schemaId" }
    },
    "interface": {
      "type": "object",
      "required": ["inputs", "outputs"],
      "properties": {
        "inputs": { "$ref": "#/$defs/ports" },
        "outputs": { "$ref": "#/$defs/ports" }
      },
      "additionalProperties": false
    },
    "node": {
      "type": "object",
      "required": ["block"],
      "properties": {
        "block": { "$ref": "#/$defs/schemaId" },
        "inputs": { "type": "object" },
        "outputs": { "type": "object" },
        "config": {},
        "bindings": { "type": "object" },
        "connection": { "type": "string", "minLength": 1 },
        "when": { "type": "string", "minLength": 1 },
        "flow": { "type": "object" },
        "effects": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          ]
        },
        "policies": { "type": "object" },
        "execution": { "type": "object" },
        "projection": { "type": "object" }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": ["interface", "nodes"],
      "properties": {
        "interface": { "$ref": "#/$defs/interface" },
        "nodes": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/name" },
          "additionalProperties": { "$ref": "#/$defs/node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge" }
        }
      },
      "additionalProperties": false
    }
  }
}
