{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graphblocks.ai/v1/plugin-manifest.schema.json",
  "title": "GraphBlocks Plugin Manifest",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "const": "graphblocks.ai/v1"
    },
    "kind": {
      "const": "PluginManifest"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "spec": {
      "$ref": "#/$defs/spec"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^\\S+$"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "namespace": {
          "$ref": "#/$defs/identifier"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "blockVersion": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "pattern": "^[1-9][0-9]*$"
        }
      ]
    },
    "inputPort": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "$ref": "#/$defs/identifier"
        },
        "required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "outputPort": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "$ref": "#/$defs/identifier"
        },
        "required": {
          "type": "boolean"
        },
        "requiredWhen": {
          "$ref": "#/$defs/outputRequirednessPredicate"
        }
      },
      "additionalProperties": false
    },
    "outputRequirednessPredicate": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "configEquals"
          ],
          "properties": {
            "configEquals": {
              "type": "object",
              "required": [
                "pointer",
                "value"
              ],
              "properties": {
                "pointer": {
                  "type": "string",
                  "maxLength": 512,
                  "pattern": "^(?:/(?:[^~/]|~[01])*)*$"
                },
                "value": true
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "phase"
          ],
          "properties": {
            "phase": {
              "enum": [
                "initial",
                "resumed"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "all"
          ],
          "properties": {
            "all": {
              "type": "array",
              "minItems": 1,
              "maxItems": 16,
              "items": {
                "$ref": "#/$defs/outputRequirednessPredicate"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "any"
          ],
          "properties": {
            "any": {
              "type": "array",
              "minItems": 1,
              "maxItems": 16,
              "items": {
                "$ref": "#/$defs/outputRequirednessPredicate"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "not"
          ],
          "properties": {
            "not": {
              "$ref": "#/$defs/outputRequirednessPredicate"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "resourceSlot": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/identifier"
        },
        "type": {
          "$ref": "#/$defs/identifier"
        },
        "optional": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "namedResourceSlot": {
      "type": "object",
      "properties": {
        "type": {
          "$ref": "#/$defs/identifier"
        },
        "optional": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "block": {
      "type": "object",
      "properties": {
        "typeId": {
          "type": "string"
        },
        "type_id": {
          "type": "string"
        },
        "block": {
          "type": "string"
        },
        "version": {
          "$ref": "#/$defs/blockVersion"
        },
        "role": {
          "$ref": "#/$defs/identifier"
        },
        "implementation": {
          "$ref": "#/$defs/identifier"
        },
        "implementationId": {
          "$ref": "#/$defs/identifier"
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inputPort"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outputPort"
          }
        },
        "resourceSlots": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/resourceSlot"
              }
            },
            {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/namedResourceSlot"
              }
            }
          ]
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "configSchema": {
          "type": "object"
        }
      },
      "required": [
        "capabilities",
        "configSchema"
      ],
      "oneOf": [
        {
          "required": [
            "typeId",
            "version"
          ],
          "properties": {
            "typeId": {
              "pattern": "^[^\\s@]+$"
            }
          }
        },
        {
          "required": [
            "type_id",
            "version"
          ],
          "properties": {
            "type_id": {
              "pattern": "^[^\\s@]+$"
            }
          }
        },
        {
          "required": [
            "block",
            "version"
          ],
          "properties": {
            "block": {
              "pattern": "^[^\\s@]+$"
            }
          }
        },
        {
          "required": [
            "typeId"
          ],
          "not": {
            "required": [
              "version"
            ]
          },
          "properties": {
            "typeId": {
              "pattern": "^[^\\s@]+@[1-9][0-9]*$"
            }
          }
        },
        {
          "required": [
            "type_id"
          ],
          "not": {
            "required": [
              "version"
            ]
          },
          "properties": {
            "type_id": {
              "pattern": "^[^\\s@]+@[1-9][0-9]*$"
            }
          }
        },
        {
          "required": [
            "block"
          ],
          "not": {
            "required": [
              "version"
            ]
          },
          "properties": {
            "block": {
              "pattern": "^[^\\s@]+@[1-9][0-9]*$"
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "required": [
        "pluginId"
      ],
      "properties": {
        "pluginId": {
          "$ref": "#/$defs/identifier"
        },
        "version": {
          "$ref": "#/$defs/identifier"
        },
        "maturity": {
          "$ref": "#/$defs/identifier"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "blocks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/block"
          }
        },
        "connectorFactories": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "adapters": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
