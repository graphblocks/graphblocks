  {
    "name": "task_plan_patch_revises_steps_and_preserves_noop_digest",
    "kind": "task_plan_patch",
    "base": {
      "planId": "plan-1",
      "objective": "answer support request",
      "revision": 1,
      "steps": [
        {
          "stepId": "draft",
          "description": "Draft response"
        }
      ]
    },
    "patch": {
      "patchId": "patch-1",
      "basePlanId": "plan-1",
      "baseRevision": 1,
      "upsertSteps": [
        {
          "stepId": "verify",
          "description": "Verify answer",
          "dependsOn": [
            "draft"
          ]
        },
        {
          "stepId": "draft",
          "description": "Draft response with citations"
        }
      ],
      "removeStepIds": [
        "missing"
      ],
      "createdAt": "2026-06-26T00:00:00Z"
    },
    "expected": {
      "revision": 2,
      "stepIds": [
        "draft",
        "verify"
      ],
      "draftDescription": "Draft response with citations",
      "noopDigestStable": true
    }
  },
