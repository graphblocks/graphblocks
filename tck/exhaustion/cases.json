        "maxAdditionalUsage": [
          {
            "kind": "model_output_tokens",
            "amount": 100,
            "unit": "tokens"
          }
        ],
        "maxAdditionalSteps": 3
      }
    },
    "atomicUnit": "turn:1",
    "admissionEpoch": 7,
    "continuationPermit": {
      "authorizedUsage": [
        {
          "kind": "model_output_tokens",
          "amount": 200,
          "unit": "tokens"
        }
      ]
    },
    "admissions": [
      {
        "workKind": "declared_finalization",
        "workEpoch": 8,
        "permit": "stored",
