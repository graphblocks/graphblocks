[
  {
    "name": "graph_v1alpha1_to_v1",
    "document": {
      "apiVersion": "graphblocks.ai/v1alpha1",
      "kind": "Graph",
      "metadata": {
        "name": "legacy-inline",
        "annotations": {
          "example.ai/source": "fixture"
        }
      },
      "spec": {
        "nodes": {
          "echo": {
            "block": "example.echo@1",
            "connection": "provider",
            "inputs": {
              "message": "$input.message"
            },
            "outputs": {
              "result": "$output.result"
            }
          }
        }
      }
    },
    "expected": {
      "document": {
        "apiVersion": "graphblocks.ai/v1",
        "kind": "Graph",
        "metadata": {
          "name": "legacy-inline",
          "annotations": {
            "example.ai/source": "fixture",
            "graphblocks.ai/migratedFrom": "graphblocks.ai/v1alpha1"
          }
        },
        "spec": {
          "nodes": {
            "echo": {
              "block": "example.echo@1",
              "connection": "provider",
              "inputs": {
                "message": "$input.message"
              },
              "outputs": {
                "result": "$output.result"
              }
            }
          }
        }
      },
      "normalized": {
        "apiVersion": "graphblocks.ai/v1",
        "kind": "Graph",
        "metadata": {
          "name": "legacy-inline",
          "annotations": {
            "example.ai/source": "fixture",
            "graphblocks.ai/migratedFrom": "graphblocks.ai/v1alpha1"
          }
        },
        "spec": {
          "nodes": {
            "echo": {
              "block": "example.echo@1",
              "bindings": {
                "default": "provider"
              }
            }
          },
          "edges": [
            {
              "from": "$input.message",
              "to": "echo.message"
            },
            {
              "from": "echo.result",
              "to": "$output.result"
            }
          ]
        }
      }
    }
  },
