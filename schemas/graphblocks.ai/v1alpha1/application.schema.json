{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graphblocks.ai/v1alpha1/application.schema.json",
  "title": "GraphBlocks ApplicationSpec",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "graphblocks.ai/v1alpha1" },
    "kind": { "const": "Application" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": { "$ref": "#/$defs/spec" }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9._-]*$"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "namespace": { "$ref": "#/$defs/name" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "surface": {
      "type": "object",
      "required": ["kind", "protocol"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "protocol": { "type": "string", "minLength": 1 },
        "implementation": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "route": {
      "type": "object",
      "required": ["id", "method", "path"],
      "properties": {
        "id": { "$ref": "#/$defs/name" },
        "method": {
          "type": "string",
          "enum": ["DELETE", "GET", "PATCH", "POST", "PUT"]
        },
        "path": { "type": "string", "pattern": "^/" },
        "command": { "type": "string", "minLength": 1 },
        "graph": { "$ref": "#/$defs/name" },
        "responseMode": {
          "type": "string",
          "enum": ["accepted", "background", "sync"]
        },
        "transport": { "type": "string", "minLength": 1 },
        "cursorReplay": { "type": "boolean" }
      },
      "anyOf": [
        { "required": ["command"] },
        { "required": ["transport"] }
      ],
      "additionalProperties": false
    },
    "spec": {
      "type": "object",
      "minProperties": 1,
      "properties": {
        "surface": { "$ref": "#/$defs/surface" },
        "surfaces": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/name" },
          "additionalProperties": { "$ref": "#/$defs/surface" }
        },
        "graphs": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "$ref": "#/$defs/name" },
          "additionalProperties": { "$ref": "#/$defs/name" }
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "routes": {
          "type": "array",
          "items": { "$ref": "#/$defs/route" }
        },
        "callbackRegistration": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
