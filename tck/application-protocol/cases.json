  {
    "name": "capability_negotiation_intersects_commands_and_events",
    "kind": "capability_negotiation",
    "server": {
      "protocolVersion": "graphblocks.app.v1",
      "commands": [
        "InvokeGraph",
        "CancelRun"
      ],
      "events": [
        "RunStarted",
        "RunCompleted",
        "OutputCutoff"
      ]
    },
    "client": {
      "protocolVersion": "graphblocks.app.v1",
      "commands": [
        "CancelRun",
        "OpenArtifact"
      ],
      "events": [
        "RunCompleted",
        "OutputCutoff",
        "ArtifactReady"
      ]
    },
    "expected": {
      "protocolVersion": "graphblocks.app.v1",
      "commands": [
        "CancelRun"
      ],
      "events": [
        "OutputCutoff",
        "RunCompleted"
      ]
    }
  },
  {
    "name": "capability_negotiation_rejects_blank_protocol_version",
