  {
    "name": "redact_releases_sanitized_chunk",
    "delivery": {
      "mode": "bounded_holdback",
      "holdbackMaxTokens": 8
    },
    "operations": [
      {
        "op": "chunk",
        "sequence": 1,
        "text": "hello secret world"
      },
      {
        "op": "redact",
        "decisionId": "decision-redact",
        "acceptedThrough": 1,
        "inputDigest": "sha256:redact",
        "occurredAt": 1000,
        "redactions": [
          {
            "path": "/chunks/1/text",
            "start": 6,
            "end": 12,
            "replacement": "[redacted]"
          }
        ],
        "deliver": [
          {
            "sequence": 1,
            "text": "hello [redacted] world"
          }
        ]
      }
    ],
    "expected": {
      "lastGeneratedSequence": 1,
      "lastPolicyAcceptedSequence": 1,
      "lastClientDeliveredSequence": 1,
      "stopped": false
    }
  },
