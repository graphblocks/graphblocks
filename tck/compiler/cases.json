      "apiVersion": "graphblocks.ai/v1alpha3",
      "kind": "Graph",
      "metadata": {
        "name": "ordered"
      },
      "spec": {
        "nodes": {
          "b": {
            "block": "text.join@1",
            "config": {
              "second": 2,
              "first": 1
            }
          },
          "a": {
            "block": "text.literal@1"
          }
