{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "graphblocks.ai/v1alpha3/graph.schema.json",
  "title": "GraphBlocks GraphSpec",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "graphblocks.ai/v1alpha3" },
    "kind": { "const": "Graph" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "spec": { "$ref": "#/$defs/spec" }
  },
  "additionalProperties": false,
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9._-]*$"
    },
    "endpointName": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "schemaId": {
      "type": "string",
      "pattern": "^\\S+@[1-9][0-9]*$"
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "namespace": { "$ref": "#/$defs/name" },
        "labels": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "interface": {
      "type": "object",
      "properties": {
        "inputs": { "$ref": "#/$defs/ports" },
        "outputs": { "$ref": "#/$defs/ports" },
        "events": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "ports": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/endpointName" },
      "additionalProperties": { "$ref": "#/$defs/schemaId" }
    },
    "node": {
      "type": "object",
      "properties": {
        "block": { "$ref": "#/$defs/schemaId" },
        "slot": { "$ref": "#/$defs/name" },
        "inputs": { "type": "object" },
        "outputs": { "type": "object" },
        "config": {},
        "bindings": { "type": "object" },
        "connection": { "type": "string", "minLength": 1 },
        "when": { "type": "string", "minLength": 1 },
        "flow": { "type": "object" },
        "effects": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          ]
        },
        "policies": { "type": "object" },
        "execution": { "type": "object" },
        "projection": { "type": "object" }
      },
      "anyOf": [
        { "required": ["block"], "not": { "required": ["slot"] } },
        { "required": ["slot"], "not": { "required": ["block"] } }
      ],
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "compositionInterface": {
      "type": "object",
      "required": ["inputs", "outputs"],
      "properties": {
        "inputs": { "$ref": "#/$defs/ports" },
        "outputs": { "$ref": "#/$defs/ports" }
      },
      "additionalProperties": false
    },
    "composition": {
      "type": "object",
      "required": ["apiVersion"],
      "properties": {
        "apiVersion": { "const": "graphblocks.ai/composition/v1alpha1" },
        "imports": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/name" },
          "additionalProperties": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "slots": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/name" },
          "additionalProperties": {
            "type": "object",
            "required": ["interface", "fill"],
            "properties": {
              "interface": { "$ref": "#/$defs/compositionInterface" },
              "fill": {
                "type": "object",
                "required": ["fragment"],
                "properties": {
                  "fragment": {
                    "type": "string",
                    "pattern": "^[A-Za-z][A-Za-z0-9_-]*/[A-Za-z][A-Za-z0-9_-]*$"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "objectOrObjectArray": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": { "type": "object" }
        },
        {
          "type": "array",
          "items": { "type": "object" }
        }
      ]
    },
    "spec": {
      "type": "object",
      "required": ["nodes"],
      "properties": {
        "interface": { "$ref": "#/$defs/interface" },
        "nodes": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/endpointName" },
          "additionalProperties": { "$ref": "#/$defs/node" }
        },
        "edges": {
          "type": "array",
          "items": { "$ref": "#/$defs/edge" }
        },
        "composition": { "$ref": "#/$defs/composition" },
        "execution": { "type": "object" },
        "bindings": { "type": "object" },
        "toolExecution": { "type": "object" },
        "tool_execution": { "type": "object" },
        "eventStream": { "type": "object" },
        "event_stream": { "type": "object" },
        "asyncOperations": { "$ref": "#/$defs/objectOrObjectArray" },
        "async_operations": { "$ref": "#/$defs/objectOrObjectArray" },
        "callbackSubscriptions": { "$ref": "#/$defs/objectOrObjectArray" },
        "callback_subscriptions": { "$ref": "#/$defs/objectOrObjectArray" },
        "outputPolicy": { "type": "object" },
        "output_policy": { "type": "object" },
        "extensions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "voice": { "type": "object" },
        "state": { "type": "object" },
        "policy": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
